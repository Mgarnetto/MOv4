@model MoozicOrb.Models.CreatorViewModel

<input type="hidden" id="page-signalr-context" value="@Model.SignalRGroup" />
<input type="hidden" id="video-user-id" value="@Model.UserId" />
<input type="hidden" id="video-is-owner" value="@Model.IsCurrentUser.ToString().ToLower()" />
<input type="hidden" id="videoCarouselCollectionId" value="0" />

<div class="video-container" style="padding: 20px 0; position: relative;">

    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 25px; padding-bottom: 15px; border-bottom: 1px solid #333; flex-wrap: wrap; gap: 15px;">
        <div style="display: flex; align-items: center; gap: 15px;">
            <a href="/creator/@Model.UserId" class="spa-route" style="background: #1a1a1a; color: #fff; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; text-decoration: none; border: 1px solid #333;">
                <i class="fas fa-arrow-left"></i>
            </a>
            <img src="@(string.IsNullOrEmpty(Model.ProfilePic) ? "/img/profile_default.jpg" : Model.ProfilePic)" style="width: 50px; height: 50px; border-radius: 50%; object-fit: cover; border: 2px solid #333;">
            <h2 style="margin: 0; color: white; font-family: 'Outfit', sans-serif; font-weight: 700; font-size: 1.5rem;">@Model.DisplayName's Videos</h2>
        </div>

        @if (Model.IsCurrentUser)
        {
            <div style="display: flex; gap: 10px;">
                <button id="btnToggleVideoCarouselManager" onclick="window.toggleVideoCarouselManager()" style="background-color: transparent; color: #0dcaf0; border: 1px solid #0dcaf0; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-weight: bold; display: flex; align-items: center; gap: 8px; font-size: 14px; transition: all 0.2s;">
                    <i class="fas fa-star"></i> <span>Manage Carousel</span>
                </button>
            </div>
        }
    </div>

    <div id="video-carousel-container" style="margin-bottom: 30px;">
        <div class="text-center w-100 text-muted p-4"><i class="fas fa-spinner fa-spin"></i> Loading featured videos...</div>
    </div>

    <div id="video-series-container" style="margin-bottom: 30px;">
        <div class="text-center w-100 text-muted p-4"><i class="fas fa-spinner fa-spin"></i> Loading series...</div>
    </div>

    <h4 style="color:white; border-bottom:1px solid #333; padding-bottom:10px; margin-top:30px;">All Videos</h4>
    <div class="video-hub-grid" id="video-hub-container">
        <div style="text-align: center; width: 100%; padding: 50px 0; color: #888; grid-column: 1 / -1;">
            <i class="fas fa-spinner fa-spin fa-2x" style="margin-bottom: 15px;"></i>
            <p>Loading videos...</p>
        </div>
    </div>
</div>

@if (Model.IsCurrentUser)
{
    <div id="videoCarouselManagerDock" class="d-none" style="position: fixed; bottom: 0; left: 0; right: 0; height: 260px; background: #111; border-top: 2px solid #0dcaf0; z-index: 1040; box-shadow: 0 -10px 30px rgba(0,0,0,0.8); display: flex; flex-direction: column;">
        <div class="dock-header" style="display: flex; justify-content: space-between; align-items: center; padding: 10px 20px; background: #1a1a1a; border-bottom: 1px solid #333;">
            <div style="color: #fff; font-weight: bold; font-size: 1rem;"><i class="fas fa-film text-info me-2"></i> Featured Video Manager</div>
            <button onclick="window.saveVideoCarouselDock()" class="btn-dock-save" style="background: linear-gradient(135deg, #00d2ff, #007bff); color: white; border: none; padding: 6px 16px; border-radius: 20px; font-weight: bold; cursor: pointer; transition: transform 0.2s;">
                Save to Profile
            </button>
        </div>
        <div class="dock-slots-wrapper" style="flex-grow: 1; padding: 15px 20px; overflow-x: auto; display: flex; align-items: center;">
            <div id="videoCarouselDockSlotsContainer" style="display: flex; gap: 15px;">
            </div>
        </div>
    </div>
}

@if (Model.IsCurrentUser)
{
    <div id="video-inspector-sidebar" class="audio-inspector closed">
        <div class="inspector-header">
            <h5 id="vid-inspector-title" style="margin:0; font-weight: bold; color: #fff;">Edit Video</h5>
            <button onclick="window.closeVideoInspector()" class="btn-close-inspector"><i class="fas fa-times"></i></button>
        </div>

        <input type="hidden" id="vid-edit-target-id" />
        <input type="hidden" id="vid-edit-target-type" />

        <div class="inspector-body">

            <div style="margin-bottom: 20px;">
                <label style="color: #ccc; font-size: 0.85rem; font-weight: 600; display: block; margin-bottom: 8px;">Custom Thumbnail</label>
                <div id="vid-edit-cover-wrapper" style="position: relative; width: 100%; aspect-ratio: 16/9; background: #1a1a1a; border: 1px dashed #444; border-radius: 8px; overflow: hidden; display: flex; align-items: center; justify-content: center; cursor: pointer;" onclick="document.getElementById('vid-edit-cover-input').click()">
                    <img id="vid-edit-cover-preview" src="" style="width: 100%; height: 100%; object-fit: cover; position: absolute; top:0; left:0;">
                    <div style="position: absolute; background: rgba(0,0,0,0.5); padding: 5px 10px; border-radius: 4px; color: #fff; font-size: 0.8rem; z-index: 2;"><i class="fas fa-camera"></i> Change Image</div>
                    <input type="file" id="vid-edit-cover-input" accept="image/*" class="d-none" onchange="window.previewVideoInspectorCover(this)">
                </div>
            </div>

            <div style="margin-bottom: 20px;">
                <label style="color: #ccc; font-size: 0.85rem; font-weight: 600; display: block; margin-bottom: 8px;">Video Title</label>
                <input type="text" id="vid-edit-title" class="form-control" style="background: #1a1a1a; border: 1px solid #333; color: white;" placeholder="Enter title...">
            </div>

            <div style="margin-bottom: 20px;">
                <label style="color: #ccc; font-size: 0.85rem; font-weight: 600; display: block; margin-bottom: 8px;">Description</label>
                <textarea id="vid-edit-desc" class="form-control" style="background: #1a1a1a; border: 1px solid #333; color: white; resize: none;" rows="3" placeholder="Enter description..."></textarea>
            </div>

            <div style="display: flex; gap: 15px; margin-bottom: 20px;">
                <div style="flex: 1;">
                    <label style="color: #ccc; font-size: 0.85rem; font-weight: 600; display: block; margin-bottom: 8px;">Visibility</label>
                    <select id="vid-edit-visibility" class="form-select" style="background: #1a1a1a; border: 1px solid #333; color: white;">
                        <option value="0">Public</option>
                        <option value="1">Link Only</option>
                        <option value="2">Private</option>
                    </select>
                </div>
                <div style="flex: 1;">
                    <label style="color: #ccc; font-size: 0.85rem; font-weight: 600; display: block; margin-bottom: 8px;">Price (Unlock)</label>
                    <div class="input-group">
                        <span class="input-group-text" style="background: #222; border: 1px solid #333; border-right: none; color: #aaa;">$</span>
                        <input type="number" id="vid-edit-price" class="form-control" style="background: #1a1a1a; border: 1px solid #333; border-left: none; color: white;" placeholder="0.00" step="0.01" min="0">
                    </div>
                </div>
            </div>

            <div id="vid-inspector-lock-warning" class="alert alert-warning d-none" style="background: rgba(255, 193, 7, 0.1); border: 1px solid rgba(255, 193, 7, 0.3); color: #ffc107; font-size: 0.85rem; padding: 10px;">
                <i class="fas fa-lock me-2"></i> This video has been purchased. Metadata and thumbnails are locked to preserve the buyer's copy.
            </div>

        </div>

        <div class="inspector-footer">
            <button class="btn-dock-save" style="width: 100%; background: linear-gradient(135deg, #00d2ff, #007bff); color: white; border: none; padding: 10px; border-radius: 6px; font-weight: bold;" onclick="window.saveVideoInspector()">Save Changes</button>
        </div>
    </div>
}

<style>
    /* CSS FOR VIDEO HUB COMPONENTS */
    .video-hub-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 20px;
        width: 100%;
        align-items: start;
    }

    .vid-card {
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 8px;
        overflow: hidden;
        transition: transform 0.2s;
        position: relative;
    }

        .vid-card:hover {
            transform: scale(1.02);
            border-color: #555;
        }

    .vid-thumb-wrapper {
        width: 100%;
        aspect-ratio: 16/9;
        position: relative;
        cursor: pointer;
    }

    .vid-thumb-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.9;
        transition: opacity 0.3s;
    }

    .vid-card:hover .vid-thumb-img {
        opacity: 1;
    }

    .vid-play-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0,0,0,0.2);
        opacity: 0;
        transition: opacity 0.2s;
        pointer-events: none;
    }

    .vid-card:hover .vid-play-overlay {
        opacity: 1;
    }

    .vid-carousel-slot {
        width: 220px;
        height: 140px;
        background: #1a1a1a;
        border: 2px dashed #444;
        border-radius: 8px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: #666;
        position: relative;
        flex-shrink: 0;
        transition: all 0.2s;
    }

        .vid-carousel-slot.filled-slot {
            border: 1px solid #0dcaf0;
            background: #111;
        }

    .vid-slot-art {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-size: cover;
        background-position: center;
        opacity: 0.4;
        border-radius: 6px;
        pointer-events: none;
    }

    /* REUSE AUDIO INSPECTOR STYLES */
    .audio-inspector {
        position: fixed;
        top: 0;
        right: 0;
        width: 350px;
        height: 100vh;
        background: #121212;
        border-left: 1px solid #333;
        z-index: 1050;
        box-shadow: -5px 0 20px rgba(0,0,0,0.8);
        transition: transform 0.3s ease;
        display: flex;
        flex-direction: column;
    }

        .audio-inspector.closed {
            transform: translateX(100%);
        }
</style>